{"config":{"lang":["zh","en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u8bfe\u7a0b\u7b14\u8bb0","text":"<p>\u5728\u4ee3\u7801\u4e0e\u601d\u8003\u7684\u4ea4\u6c47\u5904\uff0c\u628a\u8bfe\u5802\u91cc\u7684\u4e00\u77e5\u4e00\u89e3\uff0c\u6162\u6162\u8a8a\u5199\u4e0b\u6765\u3002</p> <p>\u6b22\u8fce\u6765\u5230\u6211\u7684\u8bfe\u7a0b\u7b14\u8bb0\u7ad9\u3002\u8fd9\u91cc\u8bb0\u5f55\u6211\u5728\u4e13\u4e1a\u8bfe\u91cc\u7684\u9010\u7ae0\u624b\u8bb0\u2014\u2014\u4ece\u6982\u5ff5\u5230\u5b9e\u73b0\uff0c \u9644\u4e0a\u6211\u81ea\u5df1\u7684\u6ce8\u89e3\u4e0e\u590d\u76d8\u3002\u6240\u6709\u5185\u5bb9\u5728\u7ebf\u5373\u53ef\u9605\u8bfb\uff0c\u65e0\u9700\u4e0b\u8f7d\u3002</p> <p>\u5982\u4f55\u4f7f\u7528</p> <ul> <li>\u9876\u90e8\u5207\u6362\u4e0d\u540c\u8bfe\u7a0b\uff0c\u5de6\u4fa7\u76ee\u5f55\u5b9a\u4f4d\u7ae0\u8282</li> <li>\u53f3\u4e0a\u89d2  \u641c\u7d22\u4efb\u610f\u5173\u952e\u8bcd</li> <li>PDF \u7b14\u8bb0\u4f1a\u5185\u5d4c\u663e\u793a\uff0c\u6d4f\u89c8\u5668\u76f4\u63a5\u7ffb\u9605</li> </ul>"},{"location":"#_2","title":"\u8bfe\u7a0b\u76ee\u5f55","text":"<ul> <li> <p> \u64cd\u4f5c\u7cfb\u7edf</p> <p>\u8fdb\u7a0b\u4e0e\u7ebf\u7a0b\u3001\u8c03\u5ea6\u3001\u5185\u5b58\u7ba1\u7406\u3001\u5e76\u53d1\u540c\u6b65\u3001\u6587\u4ef6\u7cfb\u7edf\u2014\u2014\u4ece\u6982\u5ff5\u5230 MiniMR \u843d\u5730\u3002</p> <p> \u9605\u8bfb</p> </li> <li> <p> \u8ba1\u7b97\u673a\u7f51\u7edc</p> <p>\u81ea\u5e95\u5411\u4e0a\uff1a\u7269\u7406\u5c42\u5230\u5e94\u7528\u5c42\uff0cTCP/IP \u6808\u3001HTTP\u3001DNS\uff0c\u914d wireshark \u6293\u5305\u5b9e\u9a8c\u3002</p> <p> \u9605\u8bfb</p> </li> <li> <p> \u6570\u636e\u7ed3\u6784\u4e0e\u7b97\u6cd5</p> <p>\u4ece\u7ebf\u6027\u8868\u5230\u56fe\u3001\u4ece\u5206\u6cbb\u5230\u52a8\u6001\u89c4\u5212\u2014\u2014\u6982\u5ff5\u68b3\u7406 + \u7ecf\u5178\u9898\u590d\u76d8\uff0c\u9644\u81ea\u5df1\u7684\u5b9e\u73b0\u3002</p> <p> \u9605\u8bfb</p> </li> <li> <p> \u5206\u5e03\u5f0f\u8ba1\u7b97\u7cfb\u7edf</p> <p>\u5206\u5e03\u5f0f\u67b6\u6784\u3001\u4e00\u81f4\u6027\u4e0e\u534f\u8c03\u2014\u2014\u601d\u7ef4\u5bfc\u56fe\u4e0e\u8bfe\u7a0b\u603b\u7ed3\uff08PDF \u5185\u5d4c\u9605\u8bfb\uff09\u3002</p> <p> \u9605\u8bfb</p> </li> </ul>"},{"location":"#_3","title":"\u5173\u4e8e\u8fd9\u4e9b\u7b14\u8bb0","text":"<ul> <li> \u6301\u7eed\u66f4\u65b0\u2014\u2014\u968f\u8bfe\u7a0b\u8fdb\u5ea6\u8865\u5145</li> <li> \u624b\u5199\u4e3a\u4e3b\u2014\u2014\u81ea\u5df1\u7684\u7406\u89e3\u4e0e\u6ce8\u89e3\uff0c\u800c\u975e\u6559\u6750\u642c\u8fd0</li> <li> \u56de\u5230\u4e3b\u9875\u2014\u2014am-sush.github.io</li> </ul>"},{"location":"how-to/","title":"\u5982\u4f55\u6dfb\u52a0\u7b14\u8bb0","text":"<p>\u672c\u7ad9\u7528 MkDocs Material \u6784\u5efa\u3002 \u7b14\u8bb0\u6e90\u6587\u4ef6\u5728 <code>notes-src/</code>\uff1b\u6784\u5efa\u4ea7\u7269 <code>notes/</code> \u7531 GitHub Actions \u81ea\u52a8\u63d0\u4ea4\uff0c\u672c\u5730\u65e0\u9700\u3001\u4e5f\u4e0d\u5e94\u628a <code>notes/</code> \u52a0\u5165 git\u3002</p> <p>\u65e5\u5e38\u53ea\u9700\u63d0\u4ea4</p> <ul> <li><code>notes-src/</code> \u91cc\u7684 Markdown\u3001PDF \u7b49\u8d44\u6e90</li> <li><code>mkdocs.yml</code>\uff08\u6539\u4e86\u5bfc\u822a\u6216\u914d\u7f6e\u65f6\uff09</li> <li>push \u540e\u7ea6 1 \u5206\u949f\uff0cCI \u4f1a\u81ea\u52a8\u91cd\u5efa\u5e76\u4e0a\u4f20 <code>notes/</code></li> </ul>"},{"location":"how-to/#markdown","title":"\u4e00\u3001\u6dfb\u52a0 Markdown \u7b14\u8bb0","text":"<p>\u6700\u7b80\u5355\u7684\u65b9\u5f0f\u2014\u2014\u628a <code>.md</code> \u6587\u4ef6\u653e\u8fdb\u5bf9\u5e94\u8bfe\u7a0b\u76ee\u5f55\uff0c\u518d\u5728\u5bfc\u822a\u91cc\u767b\u8bb0\u3002</p> <p>1. \u653e\u6587\u4ef6</p> <p>\u4f8b\u5982\u52a0\u4e00\u7bc7\u300c\u8fdb\u7a0b\u4e0e\u7ebf\u7a0b\u300d\u7b14\u8bb0\uff1a</p> <pre><code>notes-src/\n\u2514\u2500\u2500 os/\n    \u2514\u2500\u2500 process-thread.md      \u2190 \u65b0\u589e\n</code></pre> <p>\u6587\u4ef6\u5f00\u5934\u5199\u4e00\u7ea7\u6807\u9898\u5373\u53ef\uff1a</p> <pre><code># \u8fdb\u7a0b\u4e0e\u7ebf\u7a0b\n\n\u8fd9\u91cc\u662f\u6b63\u6587\u2026\u2026\n</code></pre> <p>2. \u767b\u8bb0\u5230\u5bfc\u822a</p> <p>\u6253\u5f00\u4ed3\u5e93\u6839\u76ee\u5f55\u7684 <code>mkdocs.yml</code>\uff0c\u5728 <code>nav</code> \u91cc\u52a0\u4e00\u884c\uff1a</p> <pre><code>nav:\n  - \u64cd\u4f5c\u7cfb\u7edf:\n      - os/index.md\n      - \u6982\u89c8: os/process-thread.md   # \u2190 \u65b0\u589e\n</code></pre> <p>3. \u63a8\u9001</p> <pre><code>git add notes-src/ mkdocs.yml\ngit commit -m \"notes: \u65b0\u589e \u8fdb\u7a0b\u4e0e\u7ebf\u7a0b\"\ngit push\n</code></pre> <p>push \u4e4b\u540e\uff0cGitHub Action \u4f1a\u81ea\u52a8\u91cd\u5efa <code>notes/</code> \u7ad9\u70b9\uff0c\u7ea6 1 \u5206\u949f\u540e\u751f\u6548\u3002</p> <p>\u672c\u5730\u9884\u89c8</p> <p><pre><code>conda activate am-sush-notes\nmkdocs serve\n</code></pre> \u6253\u5f00 <code>http://127.0.0.1:8000</code>\uff0c\u6539\u5b8c\u5373\u65f6\u5237\u65b0\u3002</p>"},{"location":"how-to/#pdf","title":"\u4e8c\u3001\u5185\u5d4c PDF\uff08\u5728\u7ebf\u9605\u8bfb\uff0c\u4e0d\u7528\u4e0b\u8f7d\uff09","text":"<p>\u628a PDF \u653e\u8fdb\u8bfe\u7a0b\u76ee\u5f55\uff0c\u4f8b\u5982 <code>notes-src/os/assets/lab1.pdf</code>\uff0c \u7136\u540e\u7528 <code>iframe</code> \u5185\u5d4c\u2014\u2014\u6d4f\u89c8\u5668\u81ea\u5e26\u7684 PDF \u9605\u8bfb\u5668\u4f1a\u76f4\u63a5\u663e\u793a\uff0c\u8bbf\u5ba2\u65e0\u9700\u4e0b\u8f7d\u3002</p> <p>\u590d\u5236\u4e0b\u9762\u8fd9\u6bb5\u5230\u4efb\u610f <code>.md</code> \u6587\u4ef6\uff08\u8def\u5f84\u6309\u9700\u66ff\u6362\uff09\uff1a</p> <pre><code>&lt;iframe\n  src=\"../assets/lab1.pdf\"\n  width=\"100%\"\n  height=\"720\"\n  style=\"border:1px solid var(--md-default-fg-color--lightest); border-radius:6px;\"&gt;\n&lt;/iframe&gt;\n</code></pre> <p>\u8981\u70b9\uff1a</p> <ul> <li><code>src</code> \u7528\u76f8\u5bf9\u8def\u5f84\u3002\u4ece <code>notes-src/os/some-note.md</code> \u5f15\u7528\u540c\u76ee\u5f55 <code>assets/</code> \u4e0b\u7684 PDF\uff0c   \u5199 <code>assets/lab1.pdf</code>\uff1b\u4ece\u5b50\u76ee\u5f55\u5f15\u7528\u5219\u5982\u4e0a\u5199 <code>../assets/...</code>\u3002</li> <li>\u6784\u5efa\u540e PDF \u4f1a\u88ab\u590d\u5236\u5230 <code>notes/.../assets/</code>\uff0c\u94fe\u63a5\u81ea\u52a8\u6b63\u786e\u3002</li> <li><code>height</code> \u53ef\u6309\u9700\u8c03\u5927\uff1b\u79fb\u52a8\u7aef\u4f1a\u81ea\u9002\u5e94\u6eda\u52a8\u3002</li> </ul> <p>\u540c\u65f6\u63d0\u4f9b\u4e0b\u8f7d\u94fe\u63a5</p> <pre><code>[:material-download: \u4e0b\u8f7d PDF](../assets/lab1.pdf){:download}\n</code></pre>"},{"location":"how-to/#_2","title":"\u4e09\u3001\u6570\u5b66\u516c\u5f0f","text":"<p>\u5df2\u914d\u7f6e MathJax\uff0c\u76f4\u63a5\u7528 <code>$$ ... $$</code> \u5199\u884c\u95f4\u516c\u5f0f\uff0c<code>$ ... $</code> \u5199\u884c\u5185\uff1a</p> <pre><code>$$\nE = mc^2\n$$\n\n\u884c\u5185\uff1a\u5f53 $a \\ne 0$ \u65f6\uff0c\u65b9\u7a0b $ax^2 + bx + c = 0$ \u6709\u89e3\u3002\n</code></pre>"},{"location":"how-to/#markdown_1","title":"\u56db\u3001\u5e38\u7528 Markdown \u5143\u7d20","text":"<p>\u63d0\u793a\u6846</p> <p>admonition \u8bed\u6cd5\uff1a<code>!!! note \"\u6807\u9898\"</code></p> \u53ef\u6298\u53e0\u5757 <p><code>??? example \"\u6807\u9898\"</code> \u9ed8\u8ba4\u6536\u8d77\uff0c\u70b9\u51fb\u5c55\u5f00\u3002</p> Tab ATab B <pre><code>print(\"tabbed content\")\n</code></pre> <p>\u7528 <code>=== \"\u6807\u7b7e\u540d\"</code> \u505a\u9009\u9879\u5361\u3002</p>"},{"location":"how-to/#_3","title":"\u76ee\u5f55\u901f\u67e5","text":"\u8bfe\u7a0b \u76ee\u5f55 \u8def\u5f84\u524d\u7f00 \u64cd\u4f5c\u7cfb\u7edf <code>notes-src/os/</code> <code>/notes/os/</code> \u8ba1\u7b97\u673a\u7f51\u7edc <code>notes-src/networks/</code> <code>/notes/networks/</code> \u6570\u636e\u7ed3\u6784\u4e0e\u7b97\u6cd5 <code>notes-src/dsa/</code> <code>/notes/dsa/</code> \u5206\u5e03\u5f0f\u8ba1\u7b97\u7cfb\u7edf <code>notes-src/distributed/</code> <code>/notes/distributed/</code>"},{"location":"distributed/","title":"\u5206\u5e03\u5f0f\u8ba1\u7b97\u7cfb\u7edf","text":"<p>Distributed Computing Systems \u00b7 \u5206\u5e03\u5f0f\u67b6\u6784\u3001\u4e00\u81f4\u6027\u4e0e\u534f\u8c03</p> <p>\u672c\u680f\u6574\u7406\u5206\u5e03\u5f0f\u8ba1\u7b97\u7cfb\u7edf\u8bfe\u7a0b\u7b14\u8bb0\u2014\u2014\u601d\u7ef4\u5bfc\u56fe\u4e0e\u7ae0\u8282\u603b\u7ed3\uff0c\u6d4f\u89c8\u5668\u5185\u76f4\u63a5\u7ffb\u9605\u3002</p> <ul> <li>\u5bfc\u56fe</li> <li>\u8bfe\u7a0b\u603b\u7ed3</li> </ul>"},{"location":"distributed/mindmap/","title":"\u5bfc\u56fe \u00b7 \u5206\u5e03\u5f0f\u7cfb\u7edf","text":"<p> \u4e0b\u8f7d PDF</p>"},{"location":"distributed/summary/","title":"\u5206\u5e03\u5f0f\u7cfb\u7edf\u603b\u7ed3","text":"<p> \u4e0b\u8f7d PDF</p>"},{"location":"dsa/","title":"\u6570\u636e\u7ed3\u6784\u4e0e\u7b97\u6cd5","text":"<p>Data Structures &amp; Algorithms \u00b7 \u4ece\u7ebf\u6027\u8868\u5230\u56fe\uff0c\u4ece\u5206\u6cbb\u5230\u52a8\u6001\u89c4\u5212</p> <p>\u672c\u680f\u68b3\u7406\u6570\u636e\u7ed3\u6784\u4e0e\u7b97\u6cd5\u7684\u6838\u5fc3\u6982\u5ff5\uff0c\u914d\u7ecf\u5178\u9898\u590d\u76d8\u4e0e\u81ea\u5df1\u7684\u5b9e\u73b0\u6ce8\u89e3\u3002 \u4ece\u5de6\u680f\u9009\u62e9\u7ae0\u8282\u9605\u8bfb\u3002</p> <p>\u5f85\u5bfc\u5165</p> <p>\u5404\u7ae0\u8282\u5185\u5bb9\u51c6\u5907\u4e2d\u3002\u5bfc\u5165\u65b9\u6cd5\u89c1 \u5982\u4f55\u6dfb\u52a0\u7b14\u8bb0\u3002</p>"},{"location":"dsa/design/","title":"\u7b97\u6cd5\u8bbe\u8ba1","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u5206\u6cbb</li> <li>\u52a8\u6001\u89c4\u5212\uff08\u80cc\u5305\u3001\u533a\u95f4\u3001\u6811\u5f62\u3001\u72b6\u538b\uff09</li> <li>\u8d2a\u5fc3</li> <li>\u56de\u6eaf\u4e0e\u526a\u679d</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"dsa/linear/","title":"\u7ebf\u6027\u7ed3\u6784","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u6570\u7ec4\u4e0e\u52a8\u6001\u6570\u7ec4</li> <li>\u94fe\u8868\uff1a\u5355\u94fe\u3001\u53cc\u94fe\u3001\u5faa\u73af\u94fe\u8868</li> <li>\u6808\u4e0e\u961f\u5217\uff08\u542b\u5355\u8c03\u6808 / \u5355\u8c03\u961f\u5217\uff09</li> <li>\u7ecf\u5178\u9898\u590d\u76d8</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"dsa/sort-search/","title":"\u6392\u5e8f\u4e0e\u67e5\u627e","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u5feb\u6392\u3001\u5f52\u5e76\u3001\u5806\u6392</li> <li>\u5e0c\u5c14\u3001\u8ba1\u6570\u3001\u57fa\u6570\u6392\u5e8f</li> <li>\u4e8c\u5206\u67e5\u627e\u53ca\u5176\u5404\u79cd\u53d8\u5f62</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"dsa/tree-graph/","title":"\u6811\u4e0e\u56fe","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u4e8c\u53c9\u6811\u3001BST\u3001AVL\u3001\u7ea2\u9ed1\u6811</li> <li>\u5806\u4e0e\u4f18\u5148\u961f\u5217</li> <li>\u56fe\u7684\u904d\u5386\uff1aBFS / DFS</li> <li>\u6700\u77ed\u8def\uff08Dijkstra / Floyd\uff09\u3001\u6700\u5c0f\u751f\u6210\u6811\uff08Kruskal / Prim\uff09</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"networks/","title":"\u8ba1\u7b97\u673a\u7f51\u7edc","text":"<p>Computer Networks \u00b7 \u81ea\u5e95\u5411\u4e0a\uff0c\u7406\u89e3\u6570\u636e\u5982\u4f55\u5728\u7f51\u7edc\u4e2d\u6d41\u52a8</p> <p>\u672c\u680f\u6309\u300c\u81ea\u5e95\u5411\u4e0a\u300d\u7684\u987a\u5e8f\u6574\u7406\uff1a\u4ece\u7269\u7406\u5c42\u4e00\u76f4\u5230\u5e94\u7528\u5c42\uff0c\u914d\u5408 wireshark \u6293\u5305\u5b9e\u9a8c\u7b14\u8bb0\u3002 \u4ece\u5de6\u680f\u9009\u62e9\u7ae0\u8282\u9605\u8bfb\u3002</p> <p>\u5f85\u5bfc\u5165</p> <p>\u5404\u7ae0\u8282\u5185\u5bb9\u51c6\u5907\u4e2d\u3002\u5bfc\u5165\u65b9\u6cd5\u89c1 \u5982\u4f55\u6dfb\u52a0\u7b14\u8bb0\u3002</p>"},{"location":"networks/application-layer/","title":"\u5e94\u7528\u5c42","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>HTTP / HTTPS\u3001Cookie\u3001\u7f13\u5b58</li> <li>DNS \u89e3\u6790\u8fc7\u7a0b</li> <li>SMTP / POP3 / IMAP</li> <li>wireshark \u6293\u5305\u5b9e\u9a8c\u7b14\u8bb0</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"networks/network-layer/","title":"\u7f51\u7edc\u5c42","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>IPv4 / IPv6\u3001\u5b50\u7f51\u5212\u5206</li> <li>ARP\u3001ICMP</li> <li>\u8def\u7531\u7b97\u6cd5\uff1a\u8ddd\u79bb\u5411\u91cf\u3001\u94fe\u8def\u72b6\u6001</li> <li>NAT</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"networks/physical-link/","title":"\u7269\u7406\u5c42 / \u6570\u636e\u94fe\u8def\u5c42","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u4fe1\u53f7\u7f16\u7801\u4e0e\u4fe1\u9053</li> <li>CSMA/CD\u3001MAC \u5730\u5740</li> <li>\u4ee5\u592a\u7f51\u5e27\u7ed3\u6784</li> <li>\u4ea4\u6362\u673a\u539f\u7406</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"networks/transport-layer/","title":"\u4f20\u8f93\u5c42","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>UDP \u4e0e TCP \u62a5\u6587\u6bb5</li> <li>\u4e09\u6b21\u63e1\u624b\u3001\u56db\u6b21\u6325\u624b</li> <li>\u6d41\u91cf\u63a7\u5236\u4e0e\u62e5\u585e\u63a7\u5236</li> <li>\u53ef\u9760\u4f20\u8f93\u673a\u5236</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"os/","title":"\u64cd\u4f5c\u7cfb\u7edf","text":"<p>Operating Systems \u00b7 \u8fdb\u7a0b\u3001\u5185\u5b58\u3001\u5e76\u53d1\u4e0e\u7cfb\u7edf\u7684\u8fd0\u884c\u4e4b\u9053</p> <p>\u672c\u680f\u6574\u7406\u64cd\u4f5c\u7cfb\u7edf\u7684\u6838\u5fc3\u4e3b\u9898\u3002\u4ece\u5de6\u680f\u9009\u62e9\u7ae0\u8282\u9605\u8bfb\u2014\u2014\u6bcf\u7ae0\u4f1a\u9010\u6b65\u586b\u5145\uff1a\u6982\u5ff5\u68b3\u7406\u3001\u81ea\u5df1\u7684\u6ce8\u89e3\u3001 \u914d\u5408 MiniMR \u7b49\u9879\u76ee\u7684\u843d\u5730\u5b9e\u8df5\u3002</p> <p>\u5f85\u5bfc\u5165</p> <p>\u5404\u7ae0\u8282\u5185\u5bb9\u51c6\u5907\u4e2d\u3002\u5bfc\u5165\u65b9\u6cd5\u89c1 \u5982\u4f55\u6dfb\u52a0\u7b14\u8bb0\u3002</p>"},{"location":"os/concurrency/","title":"\u5e76\u53d1\u4e0e\u540c\u6b65","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u4e34\u754c\u533a\u4e0e\u4e92\u65a5</li> <li>\u4fe1\u53f7\u91cf\u3001\u7ba1\u7a0b</li> <li>\u7ecf\u5178\u95ee\u9898\uff1a\u751f\u4ea7\u8005-\u6d88\u8d39\u8005\u3001\u8bfb\u8005-\u5199\u8005\u3001\u54f2\u5b66\u5bb6\u5c31\u9910</li> <li>\u6b7b\u9501\uff1a\u6761\u4ef6\u3001\u9884\u9632\u3001\u907f\u514d\uff08\u94f6\u884c\u5bb6\u7b97\u6cd5\uff09\u3001\u68c0\u6d4b</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"os/filesystem/","title":"\u6587\u4ef6\u7cfb\u7edf","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u6587\u4ef6\u4e0e\u76ee\u5f55\u7ed3\u6784</li> <li>\u6587\u4ef6\u7684\u7269\u7406\u5b9e\u73b0\uff08\u8fde\u7eed / \u94fe\u63a5 / \u7d22\u5f15\uff09</li> <li>\u78c1\u76d8\u8c03\u5ea6\u7b97\u6cd5\uff08SCAN / C-SCAN\uff09</li> <li>\u865a\u62df\u6587\u4ef6\u7cfb\u7edf\uff08VFS\uff09</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"os/memory/","title":"\u5185\u5b58\u7ba1\u7406","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u8fde\u7eed\u5206\u914d\u4e0e\u788e\u7247</li> <li>\u5206\u9875\u3001\u5206\u6bb5\u3001\u6bb5\u9875\u5f0f</li> <li>\u865a\u62df\u5185\u5b58\u4e0e TLB</li> <li>\u9875\u9762\u7f6e\u6362\uff1aFIFO\u3001LRU\u3001Clock</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"os/process-thread/","title":"\u8fdb\u7a0b\u4e0e\u7ebf\u7a0b","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u8fdb\u7a0b\u7684\u6982\u5ff5\u3001\u72b6\u6001\u8f6c\u6362\uff08\u5c31\u7eea / \u8fd0\u884c / \u963b\u585e\uff09</li> <li>\u8fdb\u7a0b\u63a7\u5236\u5757\uff08PCB\uff09\u4e0e\u4e0a\u4e0b\u6587\u5207\u6362</li> <li>\u7ebf\u7a0b\u6a21\u578b\uff1a\u7528\u6237\u7ea7 / \u5185\u6838\u7ea7\u7ebf\u7a0b</li> <li>\u591a\u7ebf\u7a0b\u4e0e\u591a\u8fdb\u7a0b\u7684\u53d6\u820d</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"},{"location":"os/scheduling/","title":"CPU \u8c03\u5ea6","text":"<p>\u5f85\u5bfc\u5165</p> <p>\u672c\u7ae0\u5185\u5bb9\u51c6\u5907\u4e2d\u3002</p> <p>\u8ba1\u5212\u8986\u76d6\uff1a</p> <ul> <li>\u8c03\u5ea6\u6307\u6807\uff1a\u5468\u8f6c\u65f6\u95f4\u3001\u7b49\u5f85\u65f6\u95f4\u3001\u54cd\u5e94\u65f6\u95f4</li> <li>\u7ecf\u5178\u7b97\u6cd5\uff1aFCFS\u3001SJF\u3001\u8f6e\u8f6c\uff08RR\uff09</li> <li>\u591a\u7ea7\u53cd\u9988\u961f\u5217\uff08MLFQ\uff09</li> </ul> <p>\u5bfc\u5165\u540e\u8bf7\u5220\u9664\u672c\u63d0\u793a\u6846\u3002</p>"}]}